<!DOCTYPE html>
<html>
<head>
	<meta charset="UTF-8">
	<title>{{title}}</title>
	<link rel="stylesheet" href="/css/style.css" type="text/css">
</head>
<body>
	<div id="background">
		<div id="page">
			<div id="header">
				<div id="logo">
					<a href="/"><img src="/images/logo.png" alt="LOGO" height="100" width="200"></a>
				</div>
				<div id="navigation">
					<ul>
						<li><a href="/">Home</a></li>
						<li class="selected"><a href="/travel">Travel</a></li>
						<li><a href="/rooms">Rooms</a></li>
						<li><a href="/meals">Meals</a></li>
						<li><a href="/news">News</a></li>
						<li><a href="/about">About</a></li>
						<li><a href="/contact">Contact</a></li>
					</ul>
				</div>
			</div>

			<div id="contents">
				<div class="box">
					<div>
						<div class="body">
							{{#if trip}}
								<h1>{{trip.name}}</h1>
								<img src="{{trip.image}}" alt="{{trip.name}}" style="max-width:300px;">
								<p><strong>{{trip.length}}</strong> • <strong>{{trip.start}}</strong> • <strong>{{trip.perPerson}}</strong></p>
								<p><strong>Resort:</strong> {{trip.resort}}</p>
								<p>{{trip.description}}</p>
							{{else}}
								<h1>Trip Not Found</h1>
								<p>The requested trip could not be found.</p>
							{{/if}}

							<p><a href="/travel">Back to Travel</a></p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</body>
</html>